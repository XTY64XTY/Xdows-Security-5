  </Folder>
  <Folder Name="/README/">
    <File Path="README.md" />
    <File Path="README.zh-HANS.md" />
    <File Path="README.zh-HANT.md" />
  </Folder>
  <Folder Name="/Xdows-Local/">
    <Project Path="Xdows-Local-Caller/Xdows-Local-Caller.csproj" />
    <Project Path="Xdows-Local/Xdows-Local.csproj" />
