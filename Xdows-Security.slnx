<Solution>
  <Configurations>
    <Platform Name="Any CPU" />
    <Platform Name="ARM64" />
    <Platform Name="x64" />
    <Platform Name="x86" />
  </Configurations>
  <Folder Name="/Issues/">
    <File Path=".github/ISSUE_TEMPLATE/BugReport-en-US.yml" />
    <File Path=".github/ISSUE_TEMPLATE/BugReport-zh-HANS.yml" />
    <File Path=".github/ISSUE_TEMPLATE/BugReport-zh-HANT.yml" />
    <File Path=".github/ISSUE_TEMPLATE/FeatureRequest-en-US.yml" />
    <File Path=".github/ISSUE_TEMPLATE/FeatureRequest-zh-HANS.yml" />
    <File Path=".github/ISSUE_TEMPLATE/FeatureRequest-zh-HANT.yml" />
  </Folder>
  <Folder Name="/Others/">
