<?xml version="1.0" encoding="utf-8"?>
<local:OobeStepPageBase
    x:Class="Xdows_Security.Views.OOBE.OobeAppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Xdows_Security.Views.OOBE"
    xmlns:l="using:WinUI3Localizer"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="48,0,48,0" Spacing="16" Width="560">
            <TextBlock x:Name="TitleText" l:Uids.Uid="OOBE_Appearance_Title" Style="{StaticResource TitleTextBlockStyle}" TextAlignment="Center" />
            <StackPanel x:Name="ContentRoot" Spacing="8" HorizontalAlignment="Center">
                <TextBlock l:Uids.Uid="OOBE_Appearance_Content" Style="{StaticResource BodyTextBlockStyle}" TextAlignment="Center" />
                <HyperlinkButton x:Name="SkipButton" l:Uids.Uid="OOBE_Appearance_Skip" Click="SkipButton_Click" HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</local:OobeStepPageBase>
