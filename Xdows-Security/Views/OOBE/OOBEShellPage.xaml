<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Xdows_Security.Views.OOBE.OOBEShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:l="using:WinUI3Localizer"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Frame x:Name="ContentFrame" Grid.Row="0" />


        <StackPanel x:Name="ButtonPanel" Grid.Row="1" Margin="32,8,32,16" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12">
            <Button x:Name="BackButton" l:Uids.Uid="OOBE_Button_Previous" Click="BackButton_Click" MinWidth="100"/>
            <Button x:Name="NextButton" l:Uids.Uid="OOBE_Button_Next" Click="NextButton_Click" MinWidth="100"/>
        </StackPanel>
    </Grid>
</Page>
